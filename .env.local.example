# Copy to .env.local and fill in. Names only — real values live in Vercel env
# (production) and in each developer's local file. NEVER commit real values.

# Supabase (public pair is safe to expose; service role is NOT)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (menu import, onboarding, assistant)
OPENAI_API_KEY=

# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0
META_WABA_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
# Emergency opt-out only: set to 0 to skip webhook signature verification
FACEBOOK_VERIFY_SIGNATURE=

# Twilio (legacy voice/SMS)
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SIGNATURE=

# Voice (Vapi)
VAPI_PRIVATE_KEY=

# n8n engine
N8N_BASE_URL=
N8N_API_KEY=
AI_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Web push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Trello (system_logs mirror)
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_API_SECRET=
TRELLO_WEBHOOK_CALLBACK_URL=
SYSTEM_LOGS_WEBHOOK_SECRET=

# Crons / internal auth
CRON_SECRET=
IMPERSONATION_SECRET=
WORKER_SHARED_SECRET=

# Encryption keys (POS/payment/email credentials at rest)
POS_CRED_ENC_KEY=

# Rate limiting (ON by default; set 0 to disable)
RATE_LIMIT_ENABLED=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
