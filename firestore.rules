rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS FOR MULTI-TENANT RBAC ---

    // Authenticated: Verifies if the request possesses a valid Firebase Auth token.
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Tenant Isolation Check: Compares the requested document's tenant_id against 
    // the active_tenant_id custom claim injected by the backend /api/auth/tenant endpoint.
    // This physically isolates data so Tenant A cannot query Tenant B's collections.
    function isTenantMember(tenantId) {
      return isAuthenticated() && request.auth.token.active_tenant_id == tenantId;
    }
    
    // Role-Based Access Control (RBAC): Validates if the authenticated user has a specific structural role.
    // Available Roles: 'owner', 'manager', 'host', 'readonly'
    function hasTenantRole(tenantId, roles) {
      return isTenantMember(tenantId) && request.auth.token.tenant_role in roles;
    }

    // Global Admin Check: Users marked as platform admins bypass specific tenant-level boundaries.
    function isPlatformAdmin() {
      return isAuthenticated() && request.auth.token.role == 'platform_admin';
    }

    // --- GLOBAL RULES ---

    // Platform Admins retain god-mode capabilities across all collections for system maintenance.
    match /{document=**} {
      allow read, write: if isPlatformAdmin();
    }

    // Users can solely access and modify their personal base profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- TENANT ARCHITECTURE RULES ---

    // Tenants Collection
    match /tenants/{tenantId} {
      // Allows users to read basic configuration needed to render their tenant lists during the dropdown selection UI.
      allow read: if isAuthenticated();
      
      // Strict Protection: Only 'owner' or 'manager' roles can update billing/settings elements for this tenant.
      // Hosts and Read-Only users are strictly prevented from modifying config here.
      allow update: if hasTenantRole(tenantId, ['owner', 'manager']);
      
      // Only internal admins can create or delete actual tenant entities.
      allow create, delete: if isPlatformAdmin();
    }

    // Tenant Memberships Collection
    match /tenant_members/{memberId} {
      // Users must read this collection on boot to locate authorized workspaces to inject into the sidebar.
      // Or they can read it if they are already inside the tenant verifying colleagues.
      allow read: if (isAuthenticated() && resource.data.user_id == request.auth.uid) || isTenantMember(resource.data.tenant_id);
      
      // Protection: Only 'owner' or 'manager' can invite/remove people from this specific tenant instance. 
      // This stops a 'host' from escalating privileges or inviting unauthorized users.
      allow write: if hasTenantRole(resource.data.tenant_id, ['owner', 'manager']);
    }

    // --- BUSINESS ENTITY RULES ---
    
    // Guests Database
    match /guests/{guestId} {
      allow read: if isTenantMember(resource.data.tenant_id);
      // Operational capability: Hosts need to update guest visits, managers can manage profiling.
      // Read-only cannot edit client intelligence data.
      allow write: if hasTenantRole(resource.data.tenant_id, ['owner', 'manager', 'host']);
    }
    
    // Reservations Database
    match /reservations/{reservationId} {
      allow read: if isTenantMember(resource.data.tenant_id);
      
      // Creating & Updating: Operational staff ('owner', 'manager', 'host') are permitted to handle daily bookings.
      // The frontend UI dropdown logic matches this backend hard-check.
      allow create: if isTenantMember(request.resource.data.tenant_id) && 
                    hasTenantRole(request.resource.data.tenant_id, ['owner', 'manager', 'host']);
      allow update: if isTenantMember(resource.data.tenant_id) && 
                    hasTenantRole(resource.data.tenant_id, ['owner', 'manager', 'host']);
                    
      // Deleting Protection: Soft-deletes (status change) are for hosts, but hard database deletions 
      // are permanently restricted exclusively to managers and owners to guard against malicious data scrubbing.
      allow delete: if hasTenantRole(resource.data.tenant_id, ['owner', 'manager']);
    }

    // RESERVATION EVENTS (Audit Trail)
    match /reservation_events/{eventId} {
      // Clients can read events to show history in the timeline
      allow read: if isTenantMember(resource.data.tenant_id);
      
      // Clients CANNOT write directly. All events are generated securely via 
      // Server Actions (using firebase-admin) ensuring audit integrity.
      allow write: if false; 
    }

    // Waitlist System
    match /waitlist_entries/{entryId} {
      allow read: if isTenantMember(resource.data.tenant_id);
      // Waitlists run dynamically and staff must accept/decline entries in real time.
      allow write: if hasTenantRole(resource.data.tenant_id, ['owner', 'manager', 'host']);
    }

    // Multi-Channel Conversations (AI Hand-offs)
    match /conversations/{conversationId} {
      // Data is scoped: A Host in "Tenant A" will mathematically fail evaluating for "Tenant B" tickets.
      allow read: if isTenantMember(resource.data.tenant_id);
      
      // Staff interaction: Hosts must be able to inject string messages into transcripts and resolve open cases.
      allow write: if hasTenantRole(resource.data.tenant_id, ['owner', 'manager', 'host']);
    }

    // Incident Reporting System
    match /incidents/{incidentId} {
      // Real-time listener protection bounds
      allow read: if isTenantMember(resource.data.tenant_id);
      
      // Escalation paths: Incidents represent critical failures (e.g., hallucination). Hosts can trigger them, 
      // but managing and resolving the incident collection requires manager oversight.
      allow write: if hasTenantRole(resource.data.tenant_id, ['owner', 'manager']);
    }

    // Operational Knowledge Base (AI Context)
    match /knowledge_articles/{articleId} {
      allow read: if isTenantMember(resource.data.tenant_id);
      
      // System Integrity Protection: Hosts mapping bad AI context can immediately compromise bot behaviors.
      // Modifications to the KB must only be done by explicitly authorized high-level staff. 
      allow write: if hasTenantRole(resource.data.tenant_id, ['owner', 'manager']);
    }

    // Automations configuration
    match /automations/{automationId} {
      allow read: if isTenantMember(resource.data.tenant_id);
      // High-risk backend orchestration flow. Restricted fully strictly to operational owners.
      allow write: if hasTenantRole(resource.data.tenant_id, ['owner', 'manager']);
    }
  }
}
